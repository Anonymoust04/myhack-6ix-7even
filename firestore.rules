rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic rules for hackathon demo
    // In production, tighten based on request.auth.uid and roles

    match /participants/{id} {
      allow read, write: if true;
    }
    match /mentors/{id} {
      allow read, write: if true;
    }
    match /companies/{id} {
      allow read, write: if true;
    }
    match /programmes/{id} {
      allow read, write: if true;
    }
    match /relationships/{id} {
      allow read, write: if true;
    }
    match /interest_requests/{id} {
      allow read, write: if true;
    }
    match /users/{id} {
      allow read, write: if true;
    }
  }
}
